---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { normalizeLang, type Lang } from '../../i18n';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	// 为每篇文章预计算：同一篇内容在中英两种语言下的对应 entry。
	// 这样可以在语言切换时直接生成链接，而不需要在渲染期再扫一遍 collection。
	const byLangAndSlug = new Map<string, CollectionEntry<'blog'>>();
	for (const post of posts) {
		const [lang, ...rest] = post.id.split('/');
		const currentLang = normalizeLang(lang);
		const slug = rest.join('/');
		byLangAndSlug.set(`${currentLang}:${slug}`, post);
	}

	return posts.map((post) => {
		const [lang, ...rest] = post.id.split('/');
		const slug = rest.join('/');
		const currentLang = normalizeLang(lang);
		const otherLang = currentLang === 'en-US' ? 'zh-CN' : 'en-US';
		const otherPost = byLangAndSlug.get(`${otherLang}:${slug}`);
		return {
			params: { slug: post.id },
			props: {
				post,
				lang: currentLang,
				otherPostId: otherPost?.id ?? null,
			},
		};
	});
}

type Props = {
	post: CollectionEntry<'blog'>;
	lang: Lang;
	otherPostId: string | null;
};

const { post, lang, otherPostId } = Astro.props as Props;

const embed =
	Astro.url.searchParams.get('embed') === '1' || Astro.url.searchParams.get('embed') === 'true';
const otherLangHref = otherPostId
	? `/blog/${otherPostId}/` + (embed ? '?embed=1' : '')
	: undefined;

const { Content } = await render(post);
---

<BlogPost {...post.data} lang={lang} showHeader={!embed} otherLangHref={otherLangHref}>
	<Content />
</BlogPost>
