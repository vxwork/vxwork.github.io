---
import type { Lang } from '../i18n';

interface Props {
	date: Date;
	lang?: Lang;
}

const { date, lang = 'en-US' } = Astro.props;

const locale = lang === 'zh-CN' ? 'zh-CN' : 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
