---
import type { Lang } from '../i18n';
import { getLanguageLabel } from '../i18n';

interface Props {
	currentLang: Lang;
	otherLangHref?: string;
}

const { currentLang, otherLangHref } = Astro.props;

const otherLang = currentLang === 'en-US' ? 'zh-CN' : 'en-US';
const currentLabel = getLanguageLabel(currentLang);
const otherLabel = getLanguageLabel(otherLang);
---

<nav class="lang-toggle" aria-label="Language">
	<span class="current">{currentLabel}</span>
	{otherLangHref && (
		<a class="other" href={otherLangHref}>
			{otherLabel}
		</a>
	)}
</nav>

<style>
	.lang-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
	}

	.lang-toggle .current {
		color: rgb(var(--gray-dark));
		font-weight: 700;
	}

	.lang-toggle .other {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 2px solid transparent;
	}

	.lang-toggle .other:hover {
		border-bottom-color: var(--accent);
	}
</style>

